# syntax=docker/dockerfile:1.7

ARG NODE_VERSION=24
ARG DOTNET_VERSION=10.0

FROM mcr.microsoft.com/dotnet/sdk:${DOTNET_VERSION}-alpine AS openapi
WORKDIR /src

COPY RiftBench.slnx ./
COPY RiftBench.API/RiftBench.API.csproj RiftBench.API/
COPY RiftBench.Data/RiftBench.Data.csproj RiftBench.Data/

RUN dotnet restore RiftBench.API/RiftBench.API.csproj
COPY . .

# Your API build emits RiftBench.API/RiftBench.API.json.
RUN dotnet build RiftBench.API/RiftBench.API.csproj -c Release --no-restore

FROM node:${NODE_VERSION}-alpine AS deps
WORKDIR /app/web
RUN corepack enable
COPY web/package.json web/pnpm-lock.yaml ./
RUN pnpm install --frozen-lockfile

FROM deps AS build
WORKDIR /app
COPY --from=openapi /src ./
COPY --from=deps /app/web/node_modules ./web/node_modules
WORKDIR /app/web
ARG VITE_API_BASE
ENV VITE_API_BASE=${VITE_API_BASE}
RUN pnpm build
RUN pnpm prune --prod

FROM node:${NODE_VERSION}-alpine AS web
WORKDIR /app/web
ENV NODE_ENV=production
ENV HOST=0.0.0.0
ENV PORT=3000
EXPOSE 3000
RUN corepack enable
COPY --from=build /app/web ./
CMD ["node", ".output/server/index.mjs"]
