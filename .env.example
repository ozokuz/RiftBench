# Production domains
WEB_HOST=riftbench.example.com
API_HOST=api.riftbench.example.com
TRAEFIK_HOST=traefik.riftbench.example.com

# Public URL used by TanStack Start.
# Usually this should be the externally reachable API URL.
API_HTTP=https://api.riftbench.example.com

# Let's Encrypt
TRAEFIK_ACME_EMAIL=admin@example.com

# PostgreSQL
POSTGRES_DB=riftbench
POSTGRES_USER=riftbench
POSTGRES_PASSWORD=change-me

# Build/runtime versions
DOTNET_VERSION=10.0
NODE_VERSION=24

# Development-only optional overrides
POSTGRES_PORT=5432
DEV_API_HTTP=http://localhost:5036
DEV_CONNECTION_STRING=Host=localhost;Port=5432;Database=riftbench;Username=riftbench;Password=riftbench
